---
import type { Rarity } from '../lib/lgtm';
import { RARITY_LABELS } from '../lib/lgtm';

interface Props {
  rarity: Rarity;
  size?: 'sm' | 'md' | 'lg';
}

const { rarity, size = 'md' } = Astro.props;
const label = RARITY_LABELS[rarity] ?? rarity;
---

<span class={`rarity-badge badge-${rarity} size-${size}`}>
  {rarity === 'legendary' && <span class="star" aria-hidden="true">★</span>}
  {rarity === 'rare' && <span class="gem" aria-hidden="true">◆</span>}
  {label}
</span>

<style>
  .rarity-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 6px;
    white-space: nowrap;
  }

  .size-sm {
    font-size: 0.6875rem;
    padding: 0.2em 0.5em;
    border-radius: 4px;
  }

  .size-md {
    font-size: 0.75rem;
    padding: 0.3em 0.65em;
  }

  .size-lg {
    font-size: 0.875rem;
    padding: 0.4em 0.85em;
    border-radius: 8px;
  }

  .star, .gem {
    font-size: 0.85em;
    line-height: 1;
  }
</style>
