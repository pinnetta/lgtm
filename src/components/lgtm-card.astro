---
import { RARITY_LABELS } from '@/lib/lgtm';
import type { LGTMEntry } from '@/lib/lgtm';
import CategoryBadge from '@/components/category-badge.astro';

type Props = {
  entry: LGTMEntry;
  showLink?: boolean;
  variant?: 'default' | 'compact' | 'featured';
};

const { entry, variant = 'default', showLink = true } = Astro.props;
const detailUrl = `/lgtm/${entry.id}`;

const variantPadding = {
  default: 'p-6',
  compact: 'py-4 px-5',
  featured: 'py-8 px-10 rounded-2xl',
}[variant];

const meaningSize = variant === 'featured' ? 'text-[2rem]' : 'text-[1.375rem]';

const rarityStripeStyle: Record<string, string> = {
  legendary:
    'background: linear-gradient(90deg, var(--color-legendary), #f59e0b, var(--color-legendary)); background-size: 200% 100%; animation: shimmer 3s linear infinite;',

  epic: 'background: var(--color-epic);',
  rare: 'background: var(--color-rare);',
  common: 'background: var(--color-common);',
};

const badgeSize = variant === 'compact' ? 'sm' : 'md';

const rarityBadgeSizeClasses = {
  sm: 'text-[0.6875rem] py-[0.2em] px-[0.5em] rounded',
  md: 'text-[0.75rem] py-[0.3em] px-[0.65em] rounded-md',
  lg: 'text-[0.875rem] py-[0.4em] px-[0.85em] rounded-lg',
}[badgeSize];

function showTags(): boolean {
  return variant !== 'compact' && (entry.tags?.length ?? 0) > 0;
}
---

<article
  data-rarity={entry.rarity}
  onmouseout="this.style.boxShadow='';"
  style="background: var(--color-surface); border-color: var(--color-border);"
  onmouseover="this.style.boxShadow='0 4px 20px color-mix(in srgb, var(--color-accent) 12%, transparent)';"
  class={`relative overflow-hidden rounded-xl border transition-[border-color,box-shadow] duration-200 hover:border-[var(--color-accent)] ${variantPadding}`}
>
  <div
    class="absolute top-0 left-0 right-0 h-[3px] rounded-t-xl"
    style={rarityStripeStyle[entry.rarity] ?? rarityStripeStyle.common}
  >
  </div>

  <div class="mb-4">
    <div class="flex items-center gap-2 flex-wrap">
      <span
        class={`rarity-badge badge-${entry.rarity} inline-flex items-center font-semibold tracking-[0.04em] uppercase whitespace-nowrap ${rarityBadgeSizeClasses}`}
      >
        {RARITY_LABELS[entry.rarity]}
      </span>

      <CategoryBadge
        category={entry.category}
        href={`/categories/${entry.category}`}
        size={variant === 'compact' ? 'sm' : 'md'}
      />
    </div>
  </div>

  <div class="flex flex-col gap-[0.375rem]">
    <p
      class="m-0 text-[0.8125rem] font-semibold tracking-[0.12em] uppercase"
      style="font-family: var(--font-mono); color: var(--color-text-faint);"
    >
      LGTM
    </p>

    <h2 style="color: var(--color-text);" class={`m-0 font-bold leading-[1.25] tracking-[-0.01em] ${meaningSize}`}>
      {
        showLink ? (
          <a
            href={detailUrl}
            style="color: inherit;"
            onmouseout="this.style.color='inherit';"
            class="no-underline transition-colors duration-150"
            onmouseover="this.style.color='var(--color-accent)';"
          >
            {entry.meaning}
          </a>
        ) : (
          entry.meaning
        )
      }
    </h2>

    {
      entry.description && variant !== 'compact' && (
        <p style="color: var(--color-text-muted);" class="text-[0.9375rem] leading-[1.55] mt-2 mb-0">
          {entry.description}
        </p>
      )
    }
  </div>

  {
    showTags() && (
      <div style="border-color: var(--color-border);" class="mt-4 pt-[0.875rem] border-t flex flex-wrap gap-[0.375rem]">
        {entry.tags?.map((tag) => (
          <span
            class="text-[0.75rem] py-[0.1em] px-[0.4em] rounded"
            style="font-family: var(--font-mono); color: var(--color-text-faint); background: var(--color-surface-raised);"
          >
            #{tag}
          </span>
        ))}
      </div>
    )
  }
</article>
