---
import type { LGTMEntry } from '../lib/lgtm';
import RarityBadge from './rarity-badge.astro';
import CategoryBadge from './category-badge.astro';

interface Props {
  entry: LGTMEntry;
  variant?: 'default' | 'compact' | 'featured';
  showLink?: boolean;
}

const { entry, variant = 'default', showLink = true } = Astro.props;
const detailUrl = `/lgtm/${entry.id}`;
---

<article class={`lgtm-card variant-${variant}`} data-rarity={entry.rarity}>
  <div class="card-header">
    <div class="badges">
      <RarityBadge rarity={entry.rarity} size={variant === 'compact' ? 'sm' : 'md'} />
      <CategoryBadge
        category={entry.category}
        size={variant === 'compact' ? 'sm' : 'md'}
        href={`/categories/${entry.category}`}
      />
    </div>
  </div>

  <div class="card-body">
    <p class="acronym">LGTM</p>
    <h2 class="meaning">
      {showLink ? (
        <a href={detailUrl} class="meaning-link">{entry.meaning}</a>
      ) : (
        entry.meaning
      )}
    </h2>

    {entry.description && variant !== 'compact' && (
      <p class="description">{entry.description}</p>
    )}
  </div>

  {variant !== 'compact' && entry.tags && entry.tags.length > 0 && (
    <div class="card-footer">
      <div class="tags">
        {entry.tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    </div>
  )}
</article>

<style>
  .lgtm-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }

  .lgtm-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 12px 12px 0 0;
  }

  .lgtm-card[data-rarity="common"]::before    { background: var(--color-common); }
  .lgtm-card[data-rarity="rare"]::before      { background: var(--color-rare); }
  .lgtm-card[data-rarity="epic"]::before      { background: var(--color-epic); }
  .lgtm-card[data-rarity="legendary"]::before {
    background: linear-gradient(90deg, var(--color-legendary), #f59e0b, var(--color-legendary));
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
  }

  .lgtm-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .variant-featured {
    padding: 2rem 2.5rem;
    border-radius: 16px;
  }

  .variant-compact {
    padding: 1rem 1.25rem;
  }

  .card-header {
    margin-bottom: 1rem;
  }

  .badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .acronym {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-faint);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }

  .meaning {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .variant-featured .meaning {
    font-size: 2rem;
  }

  .meaning-link {
    color: inherit;
    text-decoration: none;
  }

  .meaning-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0 0;
    line-height: 1.55;
  }

  .card-footer {
    margin-top: 1rem;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-border);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-faint);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    background: var(--color-surface-raised);
  }
</style>
