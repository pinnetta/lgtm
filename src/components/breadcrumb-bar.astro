---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

type Props = {
  items: BreadcrumbItem[];
};

const { items } = Astro.props;

function isLink(item: BreadcrumbItem, i: number): boolean {
  return item.href !== undefined && i < items.length - 1;
}

function isLast(i: number): boolean {
  return i === items.length - 1;
}

function hasNext(i: number): boolean {
  return i < items.length - 1;
}
---

<nav
  aria-label="Breadcrumb"
  class="border-b py-[0.625rem]"
  style="background: var(--color-surface); border-color: var(--color-border);"
>
  <div class="container">
    <ol class="list-none m-0 p-0 flex items-center flex-wrap gap-1">
      {
        items.map((item, i) => (
          <li class="flex items-center gap-1">
            {isLink(item, i) && (
              <a
                href={item.href}
                style="color: var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-text)';"
                onmouseout="this.style.color='var(--color-text-muted)';"
                class="text-sm no-underline transition-colors duration-150"
              >
                {item.label}
              </a>
            )}

            {!isLink(item, i) && (
              <span
                class="text-sm font-medium"
                style="color: var(--color-text);"
                aria-current={isLast(i) ? 'page' : undefined}
              >
                {item.label}
              </span>
            )}

            {hasNext(i) && (
              <span class="text-sm" aria-hidden="true" style="color: var(--color-text-faint);">
                /
              </span>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</nav>
