---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav
  class="border-b py-[0.625rem]"
  style="background: var(--color-surface); border-color: var(--color-border);"
  aria-label="Breadcrumb"
>
  <div class="container">
    <ol class="list-none m-0 p-0 flex items-center flex-wrap gap-1">
      {
        items.map((item, i) => (
          <li class="flex items-center gap-1">
            {item.href && i < items.length - 1 ? (
              <a
                href={item.href}
                class="text-sm no-underline transition-colors duration-150"
                style="color: var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-text)';"
                onmouseout="this.style.color='var(--color-text-muted)';"
              >
                {item.label}
              </a>
            ) : (
              <span
                class="text-sm font-medium"
                style="color: var(--color-text);"
                aria-current={i === items.length - 1 ? 'page' : undefined}
              >
                {item.label}
              </span>
            )}
            {i < items.length - 1 && (
              <span class="text-sm" style="color: var(--color-text-faint);" aria-hidden="true">
                /
              </span>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</nav>
