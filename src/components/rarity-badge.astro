---
import { RARITY_LABELS } from '@/lib/lgtm';
import type { Rarity } from '@/lib/lgtm';

interface Props {
  rarity: Rarity;
  size?: 'sm' | 'md' | 'lg';
}

const { rarity, size = 'md' } = Astro.props;
const label = RARITY_LABELS[rarity] ?? rarity;

const sizeClasses = {
  sm: 'text-[0.6875rem] py-[0.2em] px-[0.5em] rounded',
  md: 'text-[0.75rem] py-[0.3em] px-[0.65em] rounded-md',
  lg: 'text-[0.875rem] py-[0.4em] px-[0.85em] rounded-lg',
}[size];
---

<span
  class={`rarity-badge badge-${rarity} inline-flex items-center gap-[0.3em] font-semibold tracking-[0.04em] uppercase whitespace-nowrap ${sizeClasses}`}
>
  {
    rarity === 'legendary' && (
      <span class="text-[0.85em] leading-none" aria-hidden="true">
        ★
      </span>
    )
  }
  {
    rarity === 'epic' && (
      <span class="text-[0.85em] leading-none" aria-hidden="true">
        ◆
      </span>
    )
  }
  {label}
</span>
