---
import '@/styles/global.css';
import ThemeSwitcher from '@/components/theme-switcher';
import { SITE_URL, THEME_STORAGE_KEY } from '@/lib/config';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
}

const {
  title = 'LGTM',
  description = 'A playful catalog of alternative meanings for the famous code review acronym.',
  ogTitle,
  ogDescription,
  canonicalUrl,
} = Astro.props;

const resolvedCanonical = canonicalUrl ?? new URL(Astro.url.pathname, SITE_URL).href;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const ogImageUrl = `${SITE_URL}/og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedOgDesc} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="LGTM" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline define:vars={{ THEME_STORAGE_KEY }}>
      (function () {
        try {
          const storedTheme = localStorage.getItem(THEME_STORAGE_KEY);
          if (storedTheme === 'light' || storedTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', storedTheme);
          }
        } catch {
          // localStorage may be unavailable (e.g. private browsing on some browsers)
        }
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>
  </head>

  <body>
    <header
      class="sticky top-0 z-50 border-b"
      style="background: color-mix(in srgb, var(--color-bg) 85%, transparent); backdrop-filter: blur(12px); border-color: var(--color-border);"
    >
      <div class="container">
        <nav class="flex items-center justify-between gap-4" style="height: 3.75rem;">
          <a href="/" class="flex items-baseline gap-1.5 no-underline" aria-label="LGTM home">
            <span
              class="text-lg font-semibold tracking-tight"
              style="font-family: var(--font-mono); color: var(--color-accent); letter-spacing: -0.02em;"
              >LGTM</span
            >
          </a>

          <div class="hidden sm:flex items-center gap-1.5">
            <a
              href="/browse"
              class="text-[0.9375rem] font-medium px-3 py-1.5 rounded-md no-underline transition-colors duration-150"
              style="color: var(--color-text-muted);"
              onmouseover="this.style.color='var(--color-text)';this.style.background='var(--color-surface-raised)';"
              onmouseout="this.style.color='var(--color-text-muted)';this.style.background='';"
              >Browse</a
            >
            <a
              href="/categories"
              class="text-[0.9375rem] font-medium px-3 py-1.5 rounded-md no-underline transition-colors duration-150"
              style="color: var(--color-text-muted);"
              onmouseover="this.style.color='var(--color-text)';this.style.background='var(--color-surface-raised)';"
              onmouseout="this.style.color='var(--color-text-muted)';this.style.background='';"
              >Categories</a
            >
            <a
              href="/rarities"
              class="text-[0.9375rem] font-medium px-3 py-1.5 rounded-md no-underline transition-colors duration-150"
              style="color: var(--color-text-muted);"
              onmouseover="this.style.color='var(--color-text)';this.style.background='var(--color-surface-raised)';"
              onmouseout="this.style.color='var(--color-text-muted)';this.style.background='';"
              >Rarities</a
            >
            <a href="/random" class="btn-nav-random mr-1">Random</a>
            <ThemeSwitcher client:load />
          </div>

          <div class="flex sm:hidden items-center gap-2">
            <ThemeSwitcher client:load />
            <button
              id="nav-toggle"
              class="nav-hamburger"
              aria-label="Toggle navigation"
              aria-expanded="false"
              aria-controls="mobile-menu"
            >
              <span class="bar bar-top"></span>
              <span class="bar bar-mid"></span>
              <span class="bar bar-bot"></span>
            </button>
          </div>
        </nav>
      </div>

      <div id="mobile-menu" class="mobile-menu sm:hidden" aria-hidden="true">
        <div class="container">
          <div class="mobile-menu-inner">
            <a href="/browse" class="mobile-nav-link">Browse</a>
            <a href="/categories" class="mobile-nav-link">Categories</a>
            <a href="/rarities" class="mobile-nav-link">Rarities</a>
            <a href="/random" class="mobile-nav-random">Random</a>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <footer class="footer-root border-t" style="border-color: var(--color-border);">
      <div class="container">
        <div class="footer-top">
          <div class="footer-brand">
            <span
              class="footer-logo"
              style="font-family: var(--font-mono); color: var(--color-accent);">LGTM</span
            >
            <p class="footer-tagline" style="color: var(--color-text-muted);">
              A playful catalog of alternative meanings for the famous code review acronym.
            </p>
          </div>

          <div class="footer-nav-cols">
            <div class="footer-nav-col">
              <span class="footer-col-heading" style="color: var(--color-text-faint);">Explore</span
              >
              <a href="/browse" class="footer-link" style="color: var(--color-text-muted);"
                >Browse All</a
              >
              <a href="/categories" class="footer-link" style="color: var(--color-text-muted);"
                >Categories</a
              >
              <a href="/rarities" class="footer-link" style="color: var(--color-text-muted);"
                >Rarities</a
              >
            </div>
            <div class="footer-nav-col">
              <span class="footer-col-heading" style="color: var(--color-text-faint);"
                >Discover</span
              >
              <a href="/random" class="footer-link" style="color: var(--color-text-muted);"
                >Random Entry</a
              >
              <a
                href="/rarities/legendary"
                class="footer-link"
                style="color: var(--color-text-muted);">Legendary Tier</a
              >
              <a href="/rarities/epic" class="footer-link" style="color: var(--color-text-muted);"
                >Epic Tier</a
              >
            </div>
          </div>
        </div>

        <div class="footer-divider" style="background: var(--color-border);"></div>

        <div class="footer-bottom">
          <p class="footer-copy" style="color: var(--color-text-faint);">
            &copy; {new Date().getFullYear()} LGTM. Star on
            <a
              href="https://github.com/airscripts/lgtm"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-ext-link"
              style="color: var(--color-text-muted);">GitHub</a
            >.
          </p>
          <p class="footer-copy" style="color: var(--color-text-faint);">
            Built by
            <a
              href="https://airscript.it"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-ext-link"
              style="color: var(--color-text-muted);">Airscript</a
            >.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('mobile-menu');

      toggle?.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        menu?.setAttribute('aria-hidden', String(open));
        toggle.classList.toggle('is-open', !open);
        menu?.classList.toggle('is-open', !open);
      });

      menu?.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => {
          toggle?.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
          toggle?.classList.remove('is-open');
          menu.classList.remove('is-open');
        });
      });
    </script>
  </body>
</html>

<style>
  /* ── Random button: pill that sits at the same line-height as nav text ── */
  .btn-nav-random {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.5;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition:
      background 0.15s ease,
      transform 0.1s ease,
      box-shadow 0.15s ease;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-nav-random:hover {
    background: var(--color-accent-hover);
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-accent) 40%, transparent);
  }
  .btn-nav-random:active {
    transform: translateY(0);
  }

  /* ── Hamburger ── */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    padding: 0.25rem;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s ease;
  }
  .nav-hamburger:hover {
    background: var(--color-surface-raised);
  }
  .bar {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--color-text-muted);
    transform-origin: center;
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease,
      width 0.25s ease;
  }

  /* X state */
  .nav-hamburger.is-open .bar-top {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger.is-open .bar-mid {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-hamburger.is-open .bar-bot {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile drawer ── */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    transition:
      max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease;
    opacity: 0;
    border-top: 1px solid transparent;
  }
  .mobile-menu.is-open {
    max-height: 22rem;
    opacity: 1;
    border-top-color: var(--color-border);
  }
  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.75rem 0 1rem;
  }
  .mobile-nav-link {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    padding: 0.625rem 0.5rem;
    border-radius: 8px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }
  .mobile-nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface-raised);
    text-decoration: none;
  }
  .mobile-nav-random {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    margin-top: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition:
      background 0.15s ease,
      transform 0.1s ease;
  }
  .mobile-nav-random:hover {
    background: var(--color-accent-hover);
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* ── Footer ── */
  .footer-root {
    padding: 3rem 0 1.75rem;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 639px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    max-width: 320px;
  }
  .footer-logo {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .footer-tagline {
    font-size: 0.8125rem;
    line-height: 1.6;
    margin: 0;
  }
  .footer-nav-cols {
    display: flex;
    gap: 3rem;
  }
  @media (max-width: 639px) {
    .footer-nav-cols {
      gap: 2rem;
    }
  }
  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer-col-heading {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .footer-link {
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-link:hover {
    color: var(--color-text) !important;
    text-decoration: none;
  }
  .footer-divider {
    height: 1px;
    margin: 2rem 0 1.25rem;
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .footer-copy {
    font-size: 0.8125rem;
    margin: 0;
  }
  .footer-ext-link {
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .footer-ext-link:hover {
    color: var(--color-text) !important;
    border-color: var(--color-text-muted);
    text-decoration: none;
  }
</style>
