---
import '../styles/global.css';
import ThemeSwitcher from '../components/theme-switcher';
import { SITE_URL, THEME_STORAGE_KEY } from '../lib/config';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
}

const {
  title = 'LGTM — Looks Good To Me (and more)',
  description = 'A curated, playful catalog of alternative meanings for the acronym LGTM. Generate a random one to use in your next pull request.',
  ogTitle,
  ogDescription,
  canonicalUrl,
} = Astro.props;

const resolvedCanonical = canonicalUrl ?? new URL(Astro.url.pathname, SITE_URL).href;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const ogImageUrl = `${SITE_URL}/og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedOgDesc} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="LGTM" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline define:vars={{ THEME_STORAGE_KEY }}>
      (function () {
        try {
          var t = localStorage.getItem(THEME_STORAGE_KEY);
          if (t === 'light' || t === 'dark') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (_) {}
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <nav class="site-nav">
          <a href="/" class="site-logo" aria-label="LGTM home">
            <span class="logo-acronym">LGTM</span>
          </a>

          <div class="nav-links">
            <a href="/browse" class="nav-link">Browse</a>
            <a href="/categories" class="nav-link">Categories</a>
            <a href="/random" class="btn btn-primary nav-random-btn">Random</a>
            <ThemeSwitcher client:load />
          </div>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <p class="footer-copy">
            <span class="footer-logo">LGTM</span> &mdash; Because code review deserves more vocabulary.
          </p>
          <div class="footer-links">
            <a href="/browse">Browse all</a>
            <a href="/categories">Categories</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.75rem;
    gap: 1rem;
  }

  .site-logo {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    text-decoration: none;
  }

  .logo-acronym {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface-raised);
    text-decoration: none;
  }

  .nav-random-btn {
    margin-left: 0.25rem;
    margin-right: 0.25rem;
    padding: 0.4rem 1rem;
    font-size: 0.875rem;
  }

  .site-main {
    flex: 1;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-accent);
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-text);
  }

  @media (max-width: 480px) {
    .nav-link {
      display: none;
    }
  }
</style>
