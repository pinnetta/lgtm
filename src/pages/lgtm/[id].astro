---
import BaseLayout from '../../layouts/base-layout.astro';
import RarityBadge from '../../components/rarity-badge.astro';
import CategoryBadge from '../../components/category-badge.astro';
import CopyShareButton from '../../components/copy-share-button';
import LegendaryEffect from '../../components/legendary-effect';
import { getAllEntries } from '../../lib/lgtm';
import type { Rarity } from '../../lib/lgtm';

export async function getStaticPaths() {
  const entries = getAllEntries();

  return entries.map((entry) => ({
    params: { id: String(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const siteUrl = 'https://lgtm.airscript.it';
const shareUrl = `${siteUrl}/lgtm/${entry.id}`;

const allEntries = getAllEntries();
const currentIndex = allEntries.findIndex((e) => e.id === entry.id);
const prevEntry = currentIndex > 0 ? allEntries[currentIndex - 1] : null;
const nextEntry = currentIndex < allEntries.length - 1 ? allEntries[currentIndex + 1] : null;
---

<BaseLayout
  title={`LGTM: ${entry.meaning}`}
  description={entry.description ?? `LGTM means "${entry.meaning}" — a ${entry.rarity} ${entry.category} interpretation.`}
  ogTitle={`LGTM — ${entry.meaning}`}
  ogDescription={entry.description ?? `A ${entry.rarity} LGTM interpretation: "${entry.meaning}"`}
  canonicalUrl={shareUrl}
>
  {entry.rarity === 'legendary' && (
    <LegendaryEffect client:load />
  )}

  <div class="detail-page page-content">
    <div class="container">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/browse">Browse</a>
        <span aria-hidden="true">/</span>
        <span>#{entry.id}</span>
      </nav>

      <div class="detail-layout">
        <div class="detail-card" data-rarity={entry.rarity}>
          <div class="detail-badges">
            <RarityBadge rarity={entry.rarity as Rarity} size="lg" />
            <CategoryBadge category={entry.category} size="md" href={`/categories/${entry.category}`} />
          </div>

          <p class="detail-acronym">LGTM</p>
          <h1 class="detail-meaning">{entry.meaning}</h1>

          {entry.description && (
            <p class="detail-description">{entry.description}</p>
          )}

          {entry.tags && entry.tags.length > 0 && (
            <div class="detail-tags">
              {entry.tags.map((tag) => (
                <span class="detail-tag">#{tag}</span>
              ))}
            </div>
          )}

          <div class="detail-share">
            <p class="share-label">Share this LGTM</p>
            <div class="share-actions">
              <code class="share-url">{shareUrl}</code>
              <CopyShareButton client:load url={shareUrl} />
            </div>
          </div>
        </div>

        <div class="detail-nav">
          {prevEntry ? (
            <a href={`/lgtm/${prevEntry.id}`} class="detail-nav-btn">
              <span class="detail-nav-arrow">&larr;</span>
              <span class="detail-nav-label">
                <span class="detail-nav-hint">Previous</span>
                <span class="detail-nav-meaning">{prevEntry.meaning}</span>
              </span>
            </a>
          ) : (
            <div class="detail-nav-placeholder"></div>
          )}

          <a href="/browse" class="detail-nav-center">Browse all</a>

          {nextEntry ? (
            <a href={`/lgtm/${nextEntry.id}`} class="detail-nav-btn detail-nav-btn-right">
              <span class="detail-nav-label detail-nav-label-right">
                <span class="detail-nav-hint">Next</span>
                <span class="detail-nav-meaning">{nextEntry.meaning}</span>
              </span>
              <span class="detail-nav-arrow">&rarr;</span>
            </a>
          ) : (
            <div class="detail-nav-placeholder"></div>
          )}
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .detail-page {
    padding-block: 3rem 5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb span:last-child {
    color: var(--color-text);
    font-weight: 500;
    font-family: var(--font-mono);
  }

  .detail-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .detail-card {
    width: 100%;
    max-width: 680px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.2s;
  }

  .detail-card:hover {
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.1);
  }

  .detail-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    border-radius: 20px 20px 0 0;
  }

  .detail-card[data-rarity="common"]::before    { background: var(--color-common); }
  .detail-card[data-rarity="rare"]::before      { background: var(--color-rare); }
  .detail-card[data-rarity="epic"]::before      { background: var(--color-epic); }

  .detail-card[data-rarity="legendary"]::before {
    background: linear-gradient(90deg, var(--color-legendary), #f59e0b, var(--color-legendary));
    background-size: 200%;
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  .detail-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .detail-acronym {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-faint);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .detail-meaning {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .detail-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.75rem;
  }

  .detail-tag {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-text-faint);
    padding: 0.25em 0.6em;
    border-radius: 6px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
  }

  .detail-share {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    margin-top: 0.25rem;
  }

  .share-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.875rem;
  }

  .share-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .share-url {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.4em 0.75em;
    word-break: break-all;
    flex: 1;
    min-width: 0;
  }

  .detail-nav {
    width: 100%;
    max-width: 680px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .detail-nav-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    min-width: 0;
    overflow: hidden;
  }

  .detail-nav-btn:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--color-accent) 10%, transparent);
    text-decoration: none;
  }

  .detail-nav-btn-right {
    justify-content: flex-end;
    text-align: right;
  }

  .detail-nav-arrow {
    font-size: 1.125rem;
    color: var(--color-text-faint);
    flex-shrink: 0;
  }

  .detail-nav-label {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
    overflow: hidden;
  }

  .detail-nav-label-right {
    align-items: flex-end;
  }

  .detail-nav-hint {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .detail-nav-meaning {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .detail-nav-center {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
  }

  .detail-nav-center:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .detail-nav-placeholder {
    flex: 1;
  }

  @media (max-width: 600px) {
    .detail-card {
      padding: 1.75rem 1.5rem;
    }

    .detail-nav {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .detail-nav-center {
      grid-column: 1 / -1;
      text-align: center;
      order: -1;
    }

    .detail-nav-placeholder {
      display: none;
    }
  }
</style>
