---
import BaseLayout from '@/layouts/base-layout.astro';
import BreadcrumbBar from '@/components/breadcrumb-bar.astro';
import RarityBadge from '@/components/rarity-badge.astro';
import CategoryBadge from '@/components/category-badge.astro';
import CopyShareButton from '@/components/copy-share-button';
import LegendaryEffect from '@/components/legendary-effect';
import { getAllEntries } from '@/lib/lgtm';
import type { Rarity } from '@/lib/lgtm';
import { SITE_URL } from '@/lib/config';

export async function getStaticPaths() {
  const entries = getAllEntries();

  return entries.map((entry) => ({
    params: { id: String(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const shareUrl = `${SITE_URL}/lgtm/${entry.id}`;

const allEntries = getAllEntries();
const currentIndex = allEntries.findIndex((e) => e.id === entry.id);
const prevEntry = currentIndex > 0 ? allEntries[currentIndex - 1] : null;
const nextEntry = currentIndex < allEntries.length - 1 ? allEntries[currentIndex + 1] : null;
---

<BaseLayout
  title={`LGTM: ${entry.meaning}`}
  description={entry.description ?? `LGTM means "${entry.meaning}", a ${entry.rarity} ${entry.category} interpretation.`}
  ogTitle={`LGTM: ${entry.meaning}`}
  ogDescription={entry.description ?? `A ${entry.rarity} LGTM interpretation: "${entry.meaning}"`}
  canonicalUrl={shareUrl}
>
  {entry.rarity === 'legendary' && (
    <LegendaryEffect client:load />
  )}

  <div class="detail-page" data-rarity={entry.rarity}>
    <BreadcrumbBar items={[
      { label: 'Home', href: '/' },
      { label: 'Browse', href: '/browse' },
      { label: `#${entry.id}` },
    ]} />

    <div class="detail-body">
      <div class="detail-content animate-up">
        <div class="detail-badges">
          <RarityBadge rarity={entry.rarity as Rarity} size="lg" />
          <CategoryBadge category={entry.category} size="md" href={`/categories/${entry.category}`} />
        </div>

        <p class="detail-acronym">LGTM</p>
        <h1 class="detail-meaning">{entry.meaning}</h1>

        {entry.description && (
          <p class="detail-description">{entry.description}</p>
        )}

        {entry.tags && entry.tags.length > 0 && (
          <div class="detail-tags">
            {entry.tags.map((tag) => (
              <span class="detail-tag">#{tag}</span>
            ))}
          </div>
        )}

        <div class="detail-share">
          <p class="share-label">Share this LGTM</p>
          <div class="share-actions">
            <code class="share-url">{shareUrl}</code>
            <CopyShareButton client:load url={shareUrl} />
          </div>
        </div>
      </div>

      <nav class="detail-nav animate-up-delay-1">
        {prevEntry ? (
          <a href={`/lgtm/${prevEntry.id}`} class="detail-nav-btn">
            <span class="detail-nav-arrow">&larr;</span>
            <span class="detail-nav-label">
              <span class="detail-nav-hint">Previous</span>
              <span class="detail-nav-meaning">#{prevEntry.id}</span>
            </span>
          </a>
        ) : (
          <div class="detail-nav-placeholder"></div>
        )}

        {nextEntry ? (
          <a href={`/lgtm/${nextEntry.id}`} class="detail-nav-btn detail-nav-btn-right">
            <span class="detail-nav-label detail-nav-label-right">
              <span class="detail-nav-hint">Next</span>
              <span class="detail-nav-meaning">#{nextEntry.id}</span>
            </span>
            <span class="detail-nav-arrow">&rarr;</span>
          </a>
        ) : (
          <div class="detail-nav-placeholder"></div>
        )}
      </nav>
    </div>
  </div>
</BaseLayout>

<style>
  .detail-page {
    display: flex;
    flex: 1;
    flex-direction: column;
    transition: background 0.3s ease;
  }

  .detail-page[data-rarity="common"] {
    background: color-mix(in srgb, var(--color-common) 6%, var(--color-bg));
  }

  .detail-page[data-rarity="rare"] {
    background: color-mix(in srgb, var(--color-rare) 7%, var(--color-bg));
  }

  .detail-page[data-rarity="epic"] {
    background: color-mix(in srgb, var(--color-epic) 8%, var(--color-bg));
  }

  .detail-page[data-rarity="legendary"] {
    background: color-mix(in srgb, var(--color-legendary) 10%, var(--color-bg));
  }

  .detail-body {
    display: flex;
    flex: 1;
    justify-content: center;
    flex-direction: column;
    max-width: 680px;
    width: 100%;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-block: 3rem 2rem;
    gap: 2.5rem;
  }

  .detail-content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .detail-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .detail-acronym {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-faint);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .detail-meaning {
    font-size: clamp(1.875rem, 6vw, 2.5rem);
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .detail-description {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1.5rem;
    max-width: 55ch;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }

  .detail-tag {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-text-faint);
    padding: 0.25em 0.6em;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
    border: 1px solid var(--color-border);
  }

  .detail-share {
    margin-top: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .share-label {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
  }

  .share-actions {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
  }

  .share-url {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.4em 0.75em;
    word-break: break-all;
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .detail-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .detail-nav-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition:
      border-color 0.15s,
      transform 0.15s,
      background 0.15s,
      box-shadow 0.15s;
    min-width: 0;
    overflow: hidden;
  }

  .detail-nav-btn:hover {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-surface) 90%, transparent);
    transform: translateY(-1px);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--color-accent) 10%, transparent);
    text-decoration: none;
  }

  .detail-nav-btn-right {
    justify-content: flex-end;
    text-align: right;
  }

  .detail-nav-arrow {
    font-size: 1.125rem;
    color: var(--color-text-faint);
    flex-shrink: 0;
  }

  .detail-nav-label {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
    overflow: hidden;
  }

  .detail-nav-label-right {
    align-items: flex-end;
  }

  .detail-nav-hint {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .detail-nav-meaning {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .detail-nav-placeholder {
    flex: 1;
  }

  @media (max-width: 480px) {
    .detail-body {
      padding-block: 2rem 1.5rem;
    }

    .share-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
