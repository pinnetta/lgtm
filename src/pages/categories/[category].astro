---
import BaseLayout from '../../layouts/base-layout.astro';
import Breadcrumb from '../../components/breadcrumb.astro';
import CategoryBadge from '../../components/category-badge.astro';
import CategoryEntries from '../../components/category-entries';
import { getAllEntries, getAllCategories, CATEGORY_LABELS } from '../../lib/lgtm';

export async function getStaticPaths() {
  const entries = getAllEntries();
  const categories = getAllCategories();

  return categories.map((category) => ({
    params: { category },
    props: {
      entries: entries.filter((e) => e.category === category),
      category,
    },
  }));
}

const { entries, category } = Astro.props;
const label = CATEGORY_LABELS[category] ?? category;
---

<BaseLayout
  title={`LGTM — ${label} meanings`}
  description={`All ${entries.length} LGTM alternative meanings in the "${label}" category.`}
>
  <div class="category-page">
    <div class="container">

      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Categories', href: '/categories' },
        { label },
      ]} />

      <div class="page-header">
        <div class="header-row">
          <h1 class="page-title">{label}</h1>
          <CategoryBadge category={category} size="md" />
        </div>
        <p class="page-sub">{entries.length} entries in this category.</p>
      </div>

      <div class="back-link-row">
        <a href="/categories" class="back-link">&larr; All categories</a>
        <a href="/browse" class="back-link">Browse all &rarr;</a>
      </div>

      <CategoryEntries client:load entries={entries} />

    </div>
  </div>
</BaseLayout>

<style>
  .category-page {
    padding-block: 2.5rem 4rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
  }

  .header-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
  }

  .page-sub {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .back-link-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .back-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }
</style>
