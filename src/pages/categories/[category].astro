---
import BaseLayout from '@/layouts/base-layout.astro';
import BreadcrumbBar from '@/components/breadcrumb-bar.astro';
import CategoryBadge from '@/components/category-badge.astro';
import { CategoryEntries } from '@/components/category-entries';
import { getAllEntries, getAllCategories, CATEGORY_LABELS } from '@/lib/lgtm';

export async function getStaticPaths() {
  const entries = getAllEntries();
  const categories = getAllCategories();

  return categories.map((category) => ({
    params: { category },

    props: {
      entries: entries.filter((e) => e.category === category),
      category,
    },
  }));
}

const { entries, category } = Astro.props;
const label = CATEGORY_LABELS[category] ?? category;
---

<BaseLayout
  title={`LGTM | ${label}`}
  description={`All ${entries.length} LGTM alternative meanings in the "${label}" category.`}
>
  <BreadcrumbBar items={[{ label: 'Home', href: '/' }, { label: 'Categories', href: '/categories' }, { label }]} />

  <div class="py-10 pb-16">
    <div class="container">
      <div class="mb-6">
        <div class="flex items-center gap-4 flex-wrap mb-2">
          <h1
            style="color: var(--color-text);"
            class="text-[clamp(1.75rem,5vw,2.5rem)] font-extrabold tracking-[-0.03em] m-0"
          >
            {label}
          </h1>

          <CategoryBadge category={category} size="md" />
        </div>

        <p class="text-base m-0" style="color: var(--color-text-muted);">
          {entries.length} entries in this category.
        </p>
      </div>

      <div class="flex gap-6 mb-8">
        <a
          href="/categories"
          style="color: var(--color-text-muted); border-color: var(--color-border);"
          class="text-[0.9rem] no-underline border-b pb-[2px] transition-colors duration-150"
          onmouseover="this.style.color='var(--color-accent)';this.style.borderColor='var(--color-accent)';"
          onmouseout="this.style.color='var(--color-text-muted)';this.style.borderColor='var(--color-border)';"
        >
          &larr; All categories
        </a>

        <a
          href="/browse"
          style="color: var(--color-text-muted); border-color: var(--color-border);"
          class="text-[0.9rem] no-underline border-b pb-[2px] transition-colors duration-150"
          onmouseover="this.style.color='var(--color-accent)';this.style.borderColor='var(--color-accent)';"
          onmouseout="this.style.color='var(--color-text-muted)';this.style.borderColor='var(--color-border)';"
        >
          Browse all &rarr;
        </a>
      </div>

      <CategoryEntries client:load entries={entries} />
    </div>
  </div>
</BaseLayout>
