---
import BaseLayout from '@/layouts/base-layout.astro';
import CategoryBadge from '@/components/category-badge.astro';
import { getAllEntries, getAllCategories, CATEGORY_LABELS } from '@/lib/lgtm';

const allEntries = getAllEntries();
const categories = getAllCategories();

const categoryData = categories.map((cat) => {
  const catEntries = allEntries.filter((e) => e.category === cat);
  return {
    name: cat,
    label: CATEGORY_LABELS[cat] ?? cat,
    count: catEntries.length,
    sample: catEntries.slice(0, 2),
  };
});
---

<BaseLayout
  title="LGTM"
  description="Browse LGTM alternative meanings by category: funny, sarcastic, wholesome, nerd, existential, corporate, and chaotic."
>
  <div class="py-10 pb-16">
    <div class="container">
      <div class="mb-10">
        <h1
          class="text-[clamp(1.75rem,5vw,2.5rem)] font-extrabold tracking-[-0.03em] mb-3 mt-0"
          style="color: var(--color-text);"
        >
          Categories
        </h1>
        <p class="text-[1.0625rem] m-0" style="color: var(--color-text-muted);">
          Browse LGTM meanings by tone and intent.
        </p>
      </div>

      <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
        {
          categoryData.map(({ name, count, sample }) => (
            <a
              href={`/categories/${name}`}
              class="flex flex-col gap-4 p-6 rounded-[14px] border no-underline transition-[border-color,box-shadow,transform] duration-150"
              style="background: var(--color-surface); border-color: var(--color-border);"
              data-category={name}
              onmouseover="this.style.borderColor='var(--color-accent)';this.style.boxShadow='0 4px 16px color-mix(in srgb, var(--color-accent) 10%, transparent)';this.style.transform='translateY(-2px)';"
              onmouseout="this.style.borderColor='var(--color-border)';this.style.boxShadow='';this.style.transform='';"
            >
              <div class="flex items-center justify-between gap-2">
                <span>
                  <CategoryBadge category={name} size="md" />
                </span>
                <span
                  class="text-[0.8125rem]"
                  style="color: var(--color-text-faint); font-variant-numeric: tabular-nums;"
                >
                  {count} entries
                </span>
              </div>
              <div class="flex flex-col gap-[0.375rem]">
                {sample.map((e) => (
                  <p
                    class="text-[0.9375rem] m-0 leading-[1.4] italic overflow-hidden text-ellipsis whitespace-nowrap"
                    style="color: var(--color-text-muted);"
                  >
                    &ldquo;{e.meaning}&rdquo;
                  </p>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
