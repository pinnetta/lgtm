---
import BaseLayout from '@/layouts/base-layout.astro';
import CategoryBadge from '@/components/category-badge.astro';
import { getAllEntries, getAllCategories, CATEGORY_LABELS } from '@/lib/lgtm';

const allEntries = getAllEntries();
const categories = getAllCategories();

const categoryData = categories.map((cat) => {
  const catEntries = allEntries.filter((e) => e.category === cat);
  return {
    name: cat,
    label: CATEGORY_LABELS[cat] ?? cat,
    count: catEntries.length,
    sample: catEntries.slice(0, 2),
  };
});
---

<BaseLayout
  title="LGTM"
  description="Browse LGTM alternative meanings by category: funny, sarcastic, wholesome, nerd, existential, corporate, and chaotic."
>
  <div class="categories-page">
    <div class="container">

      <div class="page-header">
        <h1 class="page-title">Categories</h1>
        <p class="page-sub">
          Browse LGTM meanings by tone and intent.
        </p>
      </div>

      <div class="categories-grid">
        {categoryData.map(({ name, label, count, sample }) => (
          <a href={`/categories/${name}`} class="cat-card" data-category={name}>
            <div class="cat-card-header">
              <span class="cat-name">
                <CategoryBadge category={name} size="md" />
              </span>
              <span class="cat-count">{count} entries</span>
            </div>
            <div class="cat-samples">
              {sample.map((e) => (
                <p class="cat-sample">&ldquo;{e.meaning}&rdquo;</p>
              ))}
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .categories-page {
    padding-block: 2.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .page-sub {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .cat-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cat-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-accent) 10%, transparent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .cat-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .cat-count {
    font-size: 0.8125rem;
    color: var(--color-text-faint);
    font-variant-numeric: tabular-nums;
  }

  .cat-samples {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .cat-sample {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
    font-style: italic;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
