---
import BaseLayout from '@/layouts/base-layout.astro';
import BrowseFilters from '@/components/browse-filters';
import { getAllEntries } from '@/lib/lgtm';

const entries = getAllEntries();
---

<BaseLayout
  title="LGTM"
  description={`All ${entries.length} alternative meanings of LGTM, filterable by category, rarity, and searchable by keyword.`}
>
  <div class="py-10 pb-16">
    <div class="container">
      <div class="mb-10">
        <h1
          class="text-[clamp(1.75rem,5vw,2.5rem)] font-extrabold tracking-[-0.03em] mb-3 mt-0"
          style="color: var(--color-text);"
        >
          Browse all <span style="font-family: var(--font-mono); color: var(--color-accent);"
            >LGTM</span
          > meanings
        </h1>
        <p class="text-[1.0625rem] m-0 leading-relaxed" style="color: var(--color-text-muted);">
          {entries.length} entries across all categories and rarities. Filter, search, and find the perfect
          one for your PR.
        </p>
      </div>

      <BrowseFilters client:load entries={entries} />
    </div>
  </div>
</BaseLayout>
